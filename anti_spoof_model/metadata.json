{
    "source_notebook_style": "faber24/face-anti-spoofing-detection-using-mobilenetv2",
    "dataset": "user_uploaded_dataset",
    "input_directory": "/content/antispoof_dataset_split",
    "train_directory": "/content/antispoof_dataset_split/train",
    "validation_directory": "/content/antispoof_dataset_split/val",
    "test_directory": "/content/antispoof_dataset_split/test",
    "class_mapping": {
        "real": 0,
        "spoof": 1
    },
    "sigmoid_output": "probability of class index 1",
    "positive_class": "spoof",
    "class_index_0": "real",
    "class_index_1": "spoof",
    "decision_rule": {
        "spoof_score >= threshold": "reject_as_spoof",
        "spoof_score < threshold": "continue_to_face_recognition"
    },
    "recommended_threshold_start": 0.5,
    "security_threshold_range_to_test": [
        0.3,
        0.5
    ],
    "input_size": [
        224,
        224,
        3
    ],
    "preprocessing": "rescale 1./255",
    "batch_size": 32,
    "epochs": 15,
    "learning_rate": 5e-05,
    "freezed_backbone": false,
    "auto_split_ratios": {
        "train": 0.7,
        "val": 0.2,
        "test": 0.1
    }
}